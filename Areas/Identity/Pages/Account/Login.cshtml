@page
@model CatShelter.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Sign In";
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 500px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">Welcome Back</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Sign in to Paws & Hearts Shelter</p>
    </div>

    <div class="p-4 p-md-5">

        <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

        <form id="account" method="post">

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-semibold">Email Address</label>
                <input asp-for="Input.Email" class="form-control form-control-lg"
                       autocomplete="username" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center">
                    <label asp-for="Input.Password" class="form-label fw-semibold mb-0">Password</label>
                    <a asp-page="./ForgotPassword" class="small text-decoration-none" style="color: #4a7c59;">
                        Forgot password?
                    </a>
                </div>
                <input asp-for="Input.Password" class="form-control form-control-lg mt-1"
                       autocomplete="current-password" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label small text-muted">
                        Keep me signed in
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-lg w-100 fw-bold"
                    style="background-color: #f9c6ce; color: #7a3e42; border: none;">
                Sign In
            </button>

        </form>

        <hr class="my-4" />

        <div class="text-center">
            <p class="text-muted small mb-2">Don't have an account?</p>
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                   class="btn w-100"
                   style="background-color: #d4edda; color: #2e5e3e; border: none;">
                Create an Account
            </a>
        </div>

    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
