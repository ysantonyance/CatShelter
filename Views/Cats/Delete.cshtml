@model CatShelter.Models.Cat

@{
    ViewData["Title"] = "Delete " + Model.Name;
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 550px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f8d7da;">
        <h3 class="fw-bold mb-0" style="color: #842029;">Delete Cat</h3>
        <p class="mb-0 small" style="color: #842029;">This action cannot be undone</p>
    </div>

    <div class="p-4 p-md-5 text-center">

        @if (!string.IsNullOrEmpty(Model.Img))
        {
            <img src="@Model.Img" alt="@Model.Name"
                 class="rounded-circle mb-3"
                 style="width:120px; height:120px; object-fit:cover; border: 3px solid #f5c2c7;" />
        }
        else
        {
            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                 style="width:120px; height:120px; background-color: #fef6f7; border: 3px solid #f5c2c7;">
                <span class="text-muted small">No image</span>
            </div>
        }

        <h4 class="fw-bold">@Model.Name</h4>
        <p class="text-muted mb-1 small">Breed: @(Model.Breed?.Name ?? "Unknown")</p>
        <p class="text-muted mb-4 small">Weight: @Model.Kg kg</p>

        <div class="alert mb-4" role="alert"
             style="background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;">
            Are you sure you want to remove <strong>@Model.Name</strong> from the shelter?
            This action cannot be undone.
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2 justify-content-center">
                <button type="submit" class="btn px-4 fw-semibold"
                        style="background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;">
                    Yes, Delete
                </button>
                <a asp-action="Index" class="btn px-4"
                       style="background-color: #d4edda; color: #2e5e3e; border: none;">
                    Cancel
                </a>
            </div>
        </form>

    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>
