@model CatShelter.Models.Cat

@{
    ViewData["Title"] = Model.Name + " - Details";
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 650px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    @if (!string.IsNullOrEmpty(Model.Img))
    {
        <img src="@Model.Img" class="w-100" alt="@Model.Name"
             style="height:300px; object-fit:cover;" />
    }
    else
    {
        <div class="d-flex align-items-center justify-content-center"
             style="height:200px; background-color: #fef6f7;">
            <span class="text-muted small">No image available</span>
        </div>
    }

    <div class="px-4 py-4" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">@Model.Name</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Cat Details</p>
    </div>

    <div class="p-4 p-md-5">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">Breed</dt>
            <dd class="col-sm-8">@(Model.Breed?.Name ?? "Unknown")</dd>

            @{
                var birth = Model.BirthDate;
                var today = DateOnly.FromDateTime(DateTime.Today);
                var totalDays = today.DayNumber - birth.DayNumber;
                var totalWeeks = totalDays / 7;
                var totalMonths = (today.Year - birth.Year) * 12 + today.Month - birth.Month;
                var totalYears = today.Year - birth.Year;
                if (birth > today.AddYears(-totalYears)) { totalYears--; }

                string ageDisplay;
                if (totalDays < 7)
                    ageDisplay = $"{totalDays} day{(totalDays == 1 ? "" : "s")}";
                else if (totalDays < 30)
                    ageDisplay = $"{totalWeeks} week{(totalWeeks == 1 ? "" : "s")}";
                else if (totalMonths < 12)
                    ageDisplay = $"{totalMonths} month{(totalMonths == 1 ? "" : "s")}";
                else
                    ageDisplay = $"{totalYears} year{(totalYears == 1 ? "" : "s")}";
            }
            <dt class="col-sm-4 text-muted">Age</dt>
            <dd class="col-sm-8">@ageDisplay</dd>

            <dt class="col-sm-4 text-muted">Weight</dt>
            <dd class="col-sm-8">@Model.Kg kg</dd>

            <dt class="col-sm-4 text-muted">Gender</dt>
            <dd class="col-sm-8">@Model.Gender</dd>

            <dt class="col-sm-4 text-muted">Notes</dt>
            <dd class="col-sm-8">@(!string.IsNullOrWhiteSpace(Model.Description) ? Model.Description : "No info")</dd>

            <dt class="col-sm-4 text-muted">Adoption Status</dt>
            <dd class="col-sm-8">
                @if (Model.IsAdopted)
                {
                    <span class="badge"
                          style="background-color: #d4edda; color: #2e5e3e;">
                        Adopted
                    </span>
                }
                else
                {
                    <span class="badge"
                          style="background-color: #fff3cd; color: #856404;">
                        Available for Adoption
                    </span>
                }
            </dd>

            <dt class="col-sm-4 text-muted">Health</dt>
            <dd class="col-sm-8">
                @if (Model.IsHealthy)
                {
                    <span class="badge"
                          style="background-color: #f9c6ce; color: #7a3e42;">
                        Healthy
                    </span>
                }
                else
                {
                    <span class="badge"
                          style="background-color: #f8d7da; color: #842029;">
                        Needs Medical Care
                    </span>
                }
            </dd>
        </dl>
    </div>

    <div class="d-flex gap-2 px-4 pb-4">
        <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn fw-semibold"
               style="background-color: #f9c6ce; color: #7a3e42; border: none;">
            Edit
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id"
               class="btn btn-danger">
            Delete
        </a>
        <a asp-action="Index"
               class="btn ms-auto"
               style="background-color: #d4edda; color: #2e5e3e; border: none;">
            Back to List
        </a>
    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>
