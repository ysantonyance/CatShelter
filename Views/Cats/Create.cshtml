@model CatShelter.Models.Cat

@{
    ViewData["Title"] = "Add New Cat";
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 650px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">Add New Cat</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Fill in the details to add a cat to the shelter</p>
    </div>
    <div class="p-4 p-md-5">

        <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

        <form asp-action="Create">

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Whiskers" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BreedId" class="form-label fw-semibold">Breed</label>
                <select asp-for="BreedId"
                        asp-items="@(new SelectList(ViewBag.Breeds, "Id", "Name"))"
                        class="form-select">
                    <option value=""> Select Breed </option>
                </select>
                <span asp-validation-for="BreedId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Gender" class="form-label fw-semibold">Gender</label>
                <select asp-for="Gender" class="form-select"
                        asp-items="Html.GetEnumSelectList<CatShelter.Models.Gender>()">
                    <option value=""> Select Gender </option>
                </select>
                <span asp-validation-for="Gender" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BirthDate" class="form-label fw-semibold"></label>
                <input asp-for="BirthDate" class="form-control" type="date" />
                <span asp-validation-for="BirthDate" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Kg" class="form-label fw-semibold">Weight (kg)</label>
                <input asp-for="Kg" class="form-control" type="number" step="0.1" min="0" placeholder="e.g. 4.2" />
                <span asp-validation-for="Kg" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Description / Health Notes</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Img" class="form-label fw-semibold">Cat Image</label>
                <input type="file" name="imageFile" id="imageFile" class="form-control" accept="image/*" />
                <span asp-validation-for="Img" class="text-danger small"></span>
                <small class="text-muted">Upload a photo of the cat (JPG, PNG, GIF)</small>
            </div>

            <div class="mb-4 d-flex gap-4">
                <div class="form-check">
                    <input asp-for="IsAdopted" class="form-check-input" type="checkbox" />
                    <label asp-for="IsAdopted" class="form-check-label">Adopted</label>
                </div>
                <div class="form-check">
                    <input asp-for="IsHealthy" class="form-check-input" type="checkbox" />
                    <label asp-for="IsHealthy" class="form-check-label">Healthy</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn fw-semibold"
                        style="background-color: #f9c6ce; color: #7a3e42; border: none;">
                    Add Cat
                </button>
                <a asp-action="Index" class="btn"
                       style="background-color: #d4edda; color: #2e5e3e; border: none;">
                    Cancel
                </a>
            </div>

        </form>

    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
