@{
    ViewData["Title"] = "Cat Adoption Status";
    var adoptedCats = ViewBag.AdoptedCats as List<CatShelter.Models.Cat>;
    var availableCats = ViewBag.AvailableCats as List<CatShelter.Models.Cat>;
}

<style>
    body { background-color: #f0f0f0; }
    .page-wrapper {
        max-width: 1100px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
    .nav-tabs .nav-link {
        color: #7a3e42;
        border: none;
        font-weight: 600;
    }
    .nav-tabs .nav-link.active {
        background-color: #f9c6ce;
        color: #7a3e42;
        border-radius: 8px 8px 0 0;
        border-bottom: 3px solid #7a3e42;
    }
    .nav-tabs .nav-link:hover {
        background-color: #fef6f7;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">Cat Adoption Status</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Overview of adopted and available cats</p>
    </div>

    <div class="p-4 p-md-5">

        <ul class="nav nav-tabs mb-4" id="adoptionTabs">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#available">
                    Available
                    <span class="badge ms-1" style="background-color: #d4edda; color: #2e5e3e;">
                        @(availableCats?.Count ?? 0)
                    </span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#adopted">
                    Adopted
                    <span class="badge ms-1" style="background-color: #f9c6ce; color: #7a3e42;">
                        @(adoptedCats?.Count ?? 0)
                    </span>
                </button>
            </li>
        </ul>

        <div class="tab-content">

            <div class="tab-pane fade show active" id="available">
                @if (availableCats == null || !availableCats.Any())
                {
                    <p class="text-muted fst-italic">No cats currently available for adoption.</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var cat in availableCats)
                        {
                            <div class="col-md-4 col-lg-3">
                                <div class="card border-0 shadow-sm h-100" style="border-radius: 10px;">
                                    @if (!string.IsNullOrEmpty(cat.Img))
                                    {
                                        <img src="@cat.Img" class="card-img-top"
                                             style="height: 150px; object-fit: cover; border-radius: 10px 10px 0 0;" />
                                    }
                                    <div class="card-body p-3">
                                        <h6 class="fw-bold mb-1" style="color: #7a3e42;">@cat.Name</h6>
                                        <p class="text-muted small mb-2">@cat.Breed?.Name</p>
                                        <span class="badge" style="background-color: #d4edda; color: #2e5e3e; font-size: 0.7rem;">
                                            Available
                                        </span>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 p-3 pt-0">
                                        <a asp-action="Details" asp-route-id="@cat.Id"
                                           class="btn btn-sm w-100 fw-semibold"
                                           style="background-color: #f9c6ce; color: #7a3e42; border: none;">
                                            View Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="tab-pane fade" id="adopted">
                @if (adoptedCats == null || !adoptedCats.Any())
                {
                    <p class="text-muted fst-italic">No cats have been adopted yet.</p>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var cat in adoptedCats)
                        {
                            <div class="col-md-4 col-lg-3">
                                <div class="card border-0 shadow-sm h-100" style="border-radius: 10px; opacity: 0.85;">
                                    @if (!string.IsNullOrEmpty(cat.Img))
                                    {
                                        <img src="@cat.Img" class="card-img-top"
                                             style="height: 150px; object-fit: cover; border-radius: 10px 10px 0 0; filter: grayscale(30%);" />
                                    }
                                    <div class="card-body p-3">
                                        <h6 class="fw-bold mb-1" style="color: #7a3e42;">@cat.Name</h6>
                                        <p class="text-muted small mb-2">@cat.Breed?.Name</p>
                                        <span class="badge" style="background-color: #f8d7da; color: #842029; font-size: 0.7rem;">
                                            Adopted
                                        </span>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 p-3 pt-0">
                                        <a asp-action="Details" asp-route-id="@cat.Id"
                                           class="btn btn-sm w-100 fw-semibold"
                                           style="background-color: #f9c6ce; color: #7a3e42; border: none;">
                                            View Details
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

        </div>
    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>
