@{
    ViewData["Title"] = "Donate to a Cat";
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 620px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">Donate to a Cat</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Your donation goes directly to an unhealthy cat's treatment</p>
    </div>

    <div class="p-4 p-md-5">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger small" role="alert">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Donate" method="post">

            <div class="mb-3">
                <label class="form-label fw-semibold">Cat (optional)</label>
                <select name="catId" class="form-select">
                    <option value=""> Let us choose the most needy cat </option>
                    @foreach (var cat in ViewBag.UnhealthyCats as List<CatShelter.Models.Cat>)
                    {
                        <option value="@cat.Id">@cat.Name (@cat.Breed?.Name)</option>
                    }
                </select>
                <small class="text-muted">Leave empty to automatically help the cat with the fewest donations.</small>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Care Type</label>
                <select name="careId" class="form-select" required>
                    <option value=""> Select Care Type </option>
                    @foreach (var care in ViewBag.Cares as List<CatShelter.Models.Care>)
                    {
                        <option value="@care.Id">@care.CareName</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Amount</label>
                <div class="input-group">
                    <span class="input-group-text"
                          style="background-color: #fef6f7; border-color: #dee2e6; color: #7a3e42;">
                        €
                    </span>
                    <input type="number" name="price" class="form-control"
                           step="0.01" min="0.01" placeholder="0.00" required />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn fw-semibold"
                        style="background-color: #f9c6ce; color: #7a3e42; border: none;">
                    Donate
                </button>
                <a asp-controller="Home" asp-action="Index" class="btn"
                       style="background-color: #d4edda; color: #2e5e3e; border: none;">
                    Cancel
                </a>
            </div>

        </form>

    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>