@model CatShelter.Models.CatCare

@{
    ViewData["Title"] = "Care Record Details";
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 650px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">Care Record Details</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Full information about this care session</p>
    </div>

    <div class="p-4 p-md-5">

        <div class="d-flex align-items-center gap-3 p-3 rounded mb-4"
             style="background-color: #fef6f7; border: 1px solid #f9c6ce;">
            @if (!string.IsNullOrEmpty(Model.Cat?.Img))
            {
                <img src="@Model.Cat.Img" alt="@Model.Cat.Name"
                     class="rounded-circle"
                     style="width:60px; height:60px; object-fit:cover; border: 2px solid #f5c2c7;" />
            }
            <div>
                <h5 class="mb-0 fw-bold">@(Model.Cat?.Name ?? "Unknown Cat")</h5>
                <small class="text-muted">Breed: @(Model.Cat?.Breed?.Name ?? "—")</small>
            </div>
        </div>

        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">Care Type</dt>
            <dd class="col-sm-8">@(Model.Care?.CareName ?? "Unknown")</dd>

            <dt class="col-sm-4 text-muted">Assigned Staff</dt>
            <dd class="col-sm-8">@(Model.User?.UserName ?? Model.User?.Email ?? "Unknown")</dd>

            <dt class="col-sm-4 text-muted">Price</dt>
            <dd class="col-sm-8">
                <span class="badge"
                      style="background-color: #fef6f7; color: #7a3e42; border: 1px solid #f9c6ce;">
                    $@Model.Price.ToString("0.00")
                </span>
            </dd>

            <dt class="col-sm-4 text-muted">Status</dt>
            <dd class="col-sm-8">
                @if (Model.IsSatisfied)
                {
                    <span class="badge" style="background-color:#d4edda;color:#2e5e3e;">Completed</span>
                }
                else
                {
                    <span class="badge" style="background-color:#fff3cd;color:#856404;">Pending</span>
                }
            </dd>
        </dl>

    </div>

    <div class="d-flex gap-2 px-4 pb-4">
        <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn fw-semibold"
               style="background-color: #f9c6ce; color: #7a3e42; border: none;">
            Edit
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id"
               class="btn btn-danger">
            Delete
        </a>
        <a asp-action="Index"
               class="btn ms-auto"
               style="background-color: #d4edda; color: #2e5e3e; border: none;">
            Back to List
        </a>
    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>
