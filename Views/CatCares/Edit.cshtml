@model CatShelter.Models.CatCare

@{
    ViewData["Title"] = "Edit Care Record";
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 620px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">Edit Care Record</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Update the details for this care session</p>
    </div>

    <div class="p-4 p-md-5">

        <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="CatId" class="form-label fw-semibold">Cat</label>
                <select asp-for="CatId" class="form-select" asp-items="ViewBag.CatId">
                    <option value="">-- Select Cat --</option>
                </select>
                <span asp-validation-for="CatId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CareId" class="form-label fw-semibold">Care Type</label>
                <select asp-for="CareId" class="form-select">
                    <option value="">-- Select Care Type --</option>
                    @foreach (var care in ViewBag.Cares)
                    {
                        <option value="@care.Id">@care.CareName</option>
                    }
                </select>
                <span asp-validation-for="CareId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="UserId" class="form-label fw-semibold">Assigned Staff</label>
                <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId">
                    <option value="">-- Select Staff Member --</option>
                </select>
                <span asp-validation-for="UserId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label fw-semibold">Price ($)</label>
                <div class="input-group">
                    <span class="input-group-text"
                          style="background-color: #fef6f7; border-color: #dee2e6; color: #7a3e42;">
                        $
                    </span>
                    <input asp-for="Price" class="form-control" type="number"
                           step="0.01" min="0" />
                </div>
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="mb-3 form-check">
                    <input asp-for="IsSatisfied" class="form-check-input" type="checkbox" />
                    <label asp-for="IsSatisfied" class="form-check-label">Care Completed</label>
                </div>
            }
            else
            {
                <div class="mb-3">
                    <label class="form-label">Care Completed</label>
                    <input class="form-control" value="@(Model.IsSatisfied ? "Yes" : "No")" readonly />
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn fw-semibold"
                        style="background-color: #f9c6ce; color: #7a3e42; border: none;">
                    Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id"
                       class="btn"
                       style="background-color: #d4edda; color: #2e5e3e; border: none;">
                    Cancel
                </a>
            </div>

        </form>

    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
