@model CatShelter.Models.Breed

@{
    ViewData["Title"] = Model.Name + " — Breed Details";
}

<style>
    body { background-color: #f0f0f0; }
    .page-wrapper {
        max-width: 620px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    // заглавна част
    <div class="text-center py-4 px-3" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">Breed Details</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Viewing information for this breed</p>
    </div>

    <div class="p-4 p-md-5">

        <h4 class="fw-bold mb-1" style="color: #7a3e42;">@Model.Name</h4>
        <hr />

        <p class="text-muted text-uppercase small fw-semibold mb-1">Description</p>
        <p>
            @if (string.IsNullOrWhiteSpace(Model.Description))
            {
                <span class="text-muted fst-italic">No description provided.</span>
            }
            else
            {
                @Model.Description
            }
        </p>

        @if (Model.Cats != null && Model.Cats.Any())
        {
            <hr />
            <p class="text-muted text-uppercase small fw-semibold mb-2">
                Cats of this Breed
                <span class="badge ms-1" style="background-color: #f9c6ce; color: #7a3e42;">@Model.Cats.Count</span>
            </p>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var cat in Model.Cats)
                {
                    <a asp-controller="Cats" asp-action="Details" asp-route-id="@cat.Id"
                       class="btn btn-sm"
                       style="background-color: #d4edda; color: #2e5e3e; border: none;">
                        @cat.Name
                    </a>
                }
            </div>
        }
        else
        {
            <hr />
            <p class="text-muted fst-italic">No cats registered under this breed yet.</p>
        }

        <hr />
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn fw-semibold"
               style="background-color: #f9c6ce; color: #7a3e42; border: none;">
                Edit
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn fw-semibold"
               style="background-color: #f8d7da; color: #842029; border: none;">
                Delete
            </a>
            <a asp-action="Index" class="btn ms-auto"
               style="background-color: #d4edda; color: #2e5e3e; border: none;">
                Back to List
            </a>
        </div>

    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>
</div>
