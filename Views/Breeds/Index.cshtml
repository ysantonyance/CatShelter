@model IEnumerable<CatShelter.Models.Breed>

@{
    ViewData["Title"] = "Cat Breeds";
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 1000px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4" style="background-color: #d4edda; border-radius: 12px 12px 0 0;">
        <h2 class="fw-bold mb-0" style="color: #155724;">Cat Breeds</h2>
        <p class="text-muted mb-0">All registered breeds in the shelter</p>
    </div>

    <div class="p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <span class="text-muted">
                @Model.Count() breed(s) registered
            </span>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn fw-semibold"
                       style="background-color: #d4edda; color: #155724; border: 1px solid #b8dfc4;">
                    + Add New Breed
                </a>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <h4 class="text-muted">No breeds registered yet.</h4>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn fw-semibold mt-2"
                           style="background-color: #d4edda; color: #155724; border: 1px solid #b8dfc4;">
                        Add First Breed
                    </a>
                }
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
                            <div class="card-body p-3">

                                <h5 class="card-title fw-bold mb-1" style="color: #a0003a;">@item.Name</h5>

                                <p class="card-text text-muted small" style="
                                    display: -webkit-box;
                                    -webkit-line-clamp: 3;
                                    -webkit-box-orient: vertical;
                                    overflow: hidden;">
                                    @(string.IsNullOrWhiteSpace(item.Description) ? "No description provided." : item.Description)
                                </p>

                                @if (item.Cats != null)
                                {
                                    <span class="badge"
                                          style="background-color: #f9c6ce; color: #a0003a;">
                                        @item.Cats.Count cat(s) registered
                                    </span>
                                }

                            </div>

                            <div class="card-footer bg-transparent d-flex gap-2" style="border-top: 1px solid #f0f0f0;">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm fw-semibold"
                                       style="background-color: #f9c6ce; color: #a0003a; border: 1px solid #f5a8b5;">
                                    Details
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm fw-semibold"
                                           style="background-color: #fff3cd; color: #856404; border: 1px solid #ffe69c;">
                                        Edit
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm fw-semibold ms-auto"
                                           style="background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;">
                                        Delete
                                    </a>
                                }
                            </div>

                        </div>
                    </div>
                }
            </div>
        }

    </div>

    <footer class="text-center py-3 mt-4" style="background-color: #f9c6ce; border-radius: 0 0 12px 12px;">
        <small style="color: #a0003a;">&copy; @DateTime.Now.Year Paws & Hearts Cat Shelter. Made with love for cats.</small>
    </footer>

</div>
