@model CatShelter.Models.Breed

@{
    ViewData["Title"] = "Edit " + Model.Name;
}

<style>
    body { background-color: #f0f0f0; }
    .page-wrapper {
        max-width: 620px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">Edit Breed</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Updating details for <strong>@Model.Name</strong></p>
    </div>

    <div class="p-4 p-md-5">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Breed Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-semibold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn fw-semibold"
                        style="background-color: #f9c6ce; color: #7a3e42; border: none;">
                    Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn"
                   style="background-color: #d4edda; color: #2e5e3e; border: none;">
                    Cancel
                </a>
            </div>
        </form>
    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
