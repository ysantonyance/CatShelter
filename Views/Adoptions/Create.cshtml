@model CatShelter.Models.Adoption

@{
    ViewData["Title"] = "New Adoption";
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 600px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f9c6ce;">
        <h3 class="fw-bold mb-0" style="color: #7a3e42;">Record New Adoption</h3>
        <p class="mb-0 small" style="color: #7a3e42;">Fill in the details below to register an adoption</p>
    </div>

    <div class="p-4 p-md-5">

        <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

        <form asp-action="Create">

            <div class="mb-3">
                <label asp-for="CatId" class="form-label fw-semibold">Cat</label>
                <select asp-for="CatId" class="form-select" asp-items="ViewBag.CatId">
                    <option value=""> Select Cat </option>
                </select>
                <span asp-validation-for="CatId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="UserId" class="form-label fw-semibold">Adopter</label>
                <select asp-for="UserId" class="form-select" asp-items="ViewBag.UserId">
                    <option value=""> Select Adopter </option>
                </select>
                <span asp-validation-for="UserId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AdoptionDate" class="form-label fw-semibold">Adoption Date</label>
                <input asp-for="AdoptionDate" class="form-control" type="date" />
                <span asp-validation-for="AdoptionDate" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Status" class="form-label fw-semibold">Status</label>
                <select asp-for="Status" class="form-select"
                        asp-items="Html.GetEnumSelectList<CatShelter.Models.ApplicationStatus>()">
                </select>
                <span asp-validation-for="Status" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn fw-semibold"
                        style="background-color: #f9c6ce; color: #7a3e42; border: none;">
                    Save Adoption
                </button>
                <a asp-action="Index" class="btn"
                       style="background-color: #d4edda; color: #2e5e3e; border: none;">
                    Cancel
                </a>
            </div>

        </form>

    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
