@model CatShelter.Models.Adoption

@{
    ViewData["Title"] = "Delete Adoption";
}

<style>
    body {
        background-color: #f0f0f0;
    }

    .page-wrapper {
        max-width: 600px;
        margin: 40px auto;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
        overflow: hidden;
        background-color: #fff;
    }
</style>

<div class="page-wrapper">

    <div class="text-center py-4 px-3" style="background-color: #f8d7da;">
        <h3 class="fw-bold mb-0" style="color: #842029;">Delete Adoption</h3>
        <p class="mb-0 small" style="color: #842029;">This action cannot be undone</p>
    </div>

    <div class="p-4 p-md-5">

        <div class="d-flex align-items-center gap-3 p-3 rounded mb-4"
             style="background-color: #fef6f7; border: 1px solid #f9c6ce;">
            @if (!string.IsNullOrEmpty(Model.Cat?.Img))
            {
                <img src="@Model.Cat.Img" alt="@Model.Cat.Name"
                     class="rounded-circle"
                     style="width:56px; height:56px; object-fit:cover;" />
            }
            <div>
                <h5 class="mb-0 fw-bold">@(Model.Cat?.Name ?? "Unknown Cat")</h5>
                <small class="text-muted">
                    Adopter: @(Model.User?.UserName ?? Model.User?.Email ?? "Unknown")
                </small>
            </div>
        </div>

        <dl class="row mb-4">
            <dt class="col-sm-5 text-muted">Adoption Date</dt>
            <dd class="col-sm-7">@Model.AdoptionDate.ToString("dd MMMM yyyy")</dd>

            <dt class="col-sm-5 text-muted">Status</dt>
            <dd class="col-sm-7">
                @switch (Model.Status.ToString())
                {
                    case "Approved":
                        <span class="badge"
                              style="background-color: #d4edda; color: #2e5e3e;">
                            Approved
                        </span>
                        break;
                    case "Pending":
                        <span class="badge"
                              style="background-color: #fff3cd; color: #856404;">
                            Pending
                        </span>
                        break;
                    case "Rejected":
                        <span class="badge"
                              style="background-color: #f8d7da; color: #842029;">
                            Rejected
                        </span>
                        break;
                    default:
                        <span class="badge bg-secondary">@Model.Status</span>
                        break;
                }
            </dd>
        </dl>

        <div class="alert" role="alert"
             style="background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;">
            Are you sure you want to delete this adoption record? This action
            <strong>cannot be undone</strong>.
        </div>

        @if (Model.Status == CatShelter.Models.ApplicationStatus.Approved)
        {
            <div class="alert alert-warning">
                Approved adoptions cannot be deleted.
            </div>

            <div class="text-center mt-3">
                <a asp-action="Index" class="btn"
                       style="background-color: #d4edda; color: #2e5e3e; border: none;">
                    Back
                </a>
            </div>
        }
        else
        {
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex gap-2 justify-content-center mt-3">
                    <button type="submit" class="btn px-4 fw-semibold"
                            style="background-color: #f8d7da; color: #842029; border: 1px solid #f5c2c7;">
                        Yes, Delete
                    </button>

                    <a asp-action="Index" class="btn px-4"
                           style="background-color: #d4edda; color: #2e5e3e; border: none;">
                        Cancel
                    </a>
                </div>
            </form>
        }

    </div>

    <div class="text-center py-3" style="background-color: #d4edda;">
        <small style="color: #4a7c59;">&copy; @DateTime.Now.Year Paws &amp; Hearts Cat Shelter</small>
    </div>

</div>
